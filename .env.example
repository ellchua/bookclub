PORT=3000

# Notion
NOTION_API_KEY=secret_xxx
NOTION_BOOKS_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Title property in your Notion books DB (usually "Name" or "Title")
NOTION_BOOK_TITLE_PROPERTY=Name
# Author property in books DB (usually "Author")
NOTION_BOOK_AUTHOR_PROPERTY=Author
# Checkbox property in books DB (false = unread, true = read)
NOTION_BOOK_READ_PROPERTY=Read

# Optional: members database for invite autofill
NOTION_MEMBERS_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_MEMBER_NAME_PROPERTY=Name
NOTION_MEMBER_EMAIL_PROPERTY=Email
NOTION_MEMBER_ADDRESS_PROPERTY=Address
NOTION_MEMBER_CURRENT_HOST_PROPERTY=Current Host

# Resend API key for calendar invite email (resend.com)
RESEND_API_KEY=re_xxxx
